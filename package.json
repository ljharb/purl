{
	"name": "purl",
	"version": "2.1.0",
	"description": "a PURL ( https://tc54.org/purl/ ) parser and serializer",
	"main": "./index.mjs",
	"exports": {
		".": {
			"types": "./index.d.mts",
			"default": "./index.mjs"
		},
		"./parse": {
			"types": "./parse.d.mts",
			"default": "./parse.mjs"
		},
		"./stringify": {
			"types": "./stringify.d.mts",
			"default": "./stringify.mjs"
		},
		"./normalize": {
			"types": "./normalize.d.mts",
			"default": "./normalize.mjs"
		},
		"./valid": {
			"types": "./valid.d.mts",
			"default": "./valid.mjs"
		},
		"./type": {
			"types": "./type.d.mts",
			"default": "./type.mjs"
		},
		"./namespace": {
			"types": "./namespace.d.mts",
			"default": "./namespace.mjs"
		},
		"./name": {
			"types": "./name.d.mts",
			"default": "./name.mjs"
		},
		"./version": {
			"types": "./version.d.mts",
			"default": "./version.mjs"
		},
		"./qualifiers": {
			"types": "./qualifiers.d.mts",
			"default": "./qualifiers.mjs"
		},
		"./subpath": {
			"types": "./subpath.d.mts",
			"default": "./subpath.mjs"
		},
		"./eq": {
			"types": "./eq.d.mts",
			"default": "./eq.mjs"
		},
		"./compare": {
			"types": "./compare.d.mts",
			"default": "./compare.mjs"
		},
		"./from-npm": {
			"types": "./from-npm.d.mts",
			"default": "./from-npm.mjs"
		},
		"./purl": {
			"types": "./purl.d.mts",
			"default": "./purl.mjs"
		},
		"./url": {
			"types": "./url.d.mts",
			"default": "./url.mjs"
		},
		"./validate": {
			"types": "./validate.d.mts",
			"default": "./validate.mjs"
		},
		"./types": {
			"types": "./types.d.mts",
			"default": "./types.mjs"
		},
		"./package.json": "./package.json"
	},
	"bin": "./bin.mjs",
	"scripts": {
		"prepack": "git submodule update --init --recursive && npmignore --auto --commentLines=autogenerated",
		"prepublish": "not-in-publish || npm run prepublishOnly",
		"prepublishOnly": "safe-publish-latest",
		"lint": "eslint .",
		"postlint": "tsc && attw -P",
		"pretest": "npm run lint",
		"pretests-only": "git submodule update --init --recursive",
		"tests-only": "c8 tape 'test/**/*.mjs'",
		"test": "npm run tests-only",
		"posttest": "npx npm@'>= 10.2' audit --production",
		"version": "auto-changelog && git add CHANGELOG.md",
		"postversion": "auto-changelog && git add CHANGELOG.md && git commit --no-edit --amend && git tag -f \"v$(node -e \"console.log(require('./package.json').version)\")\""
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ljharb/purl.git"
	},
	"keywords": [
		"purl",
		"package url",
		"package",
		"url",
		"ecma-427"
	],
	"author": "Jordan Harband <ljharb@gmail.com>",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/ljharb/purl/issues"
	},
	"homepage": "https://github.com/ljharb/purl#readme",
	"dependencies": {
		"npm-package-arg": "^13.0.2",
		"pargs": "^1.2.2"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.2",
		"@ljharb/eslint-config": "^22.2.3",
		"@ljharb/tsconfig": "^0.3.2",
		"@types/node": "^22.19.17",
		"@types/npm-package-arg": "^6.1.4",
		"@types/tape": "^5.8.1",
		"auto-changelog": "^2.5.0",
		"c8": "^10.1.3",
		"eslint": "^9.39.4",
		"in-publish": "^2.0.1",
		"npmignore": "^0.3.5",
		"safe-publish-latest": "^2.0.0",
		"tape": "^5.9.0",
		"typescript": "next"
	},
	"engines": {
		"node": "^22.21 || ^24.11 || >= 25.2"
	},
	"auto-changelog": {
		"output": "CHANGELOG.md",
		"template": "keepachangelog",
		"unreleased": false,
		"commitLimit": false,
		"backfillLimit": false,
		"hideCredit": true
	},
	"publishConfig": {
		"ignore": [
			".github/workflows",
			"test",
			".attw.json",
			"eslint.config.mjs",
			"vendor/purl-spec/**",
			"!vendor/purl-spec/purl-types.json"
		]
	}
}
